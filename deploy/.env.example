# =============================================================
# Hop-and-Barley — Environment Variables
# Copy to .env and fill in values before running.
# =============================================================

# --- General ---
DEBUG=False
SECRET_KEY=RM3s13et-llOcEn_ftdegcibnD5c8yjeztg90K7l5Qb-PHYXkjFILmJqsdaHX_nkfQc
DOMAIN_NAME=example.com
ALLOWED_HOSTS=example.com,www.example.com
SITE_BASE_URL=https://example.com/

DJANGO_SETTINGS_MODULE=Hop-and-Barley.core.settings.prod

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/Hop-and-Barley # pragma: allowlist secret

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password

# --- Email (SMTP) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=noreply@example.com
SMTP_PASSWORD=change_me
SMTP_FROM_EMAIL=noreply@example.com
SMTP_USE_TLS=False

EMAIL_HOST=${SMTP_HOST}
EMAIL_PORT=${SMTP_PORT}
EMAIL_HOST_USER=${SMTP_USER}
EMAIL_HOST_PASSWORD=${SMTP_PASSWORD}
DEFAULT_FROM_EMAIL=${SMTP_FROM_EMAIL}
EMAIL_USE_TLS=${SMTP_USE_TLS}



# --- Gunicorn ---
GUNICORN_WORKERS=2

# --- Logging ---
LOG_LEVEL=INFO

# --- Docker Images (prod) ---
DOCKER_IMAGE_BACKEND=ghcr.io/your-org/Hop-and-Barley-backend:latest


DOCKER_IMAGE_NGINX=ghcr.io/your-org/Hop-and-Barley-nginx:latest
